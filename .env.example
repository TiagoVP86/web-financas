# Copie este arquivo para .env e preencha com suas credenciais
# cp .env.example .env

# Banco de dados (PostgreSQL)
DATABASE_URL=

# NextAuth — gere com: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Groq AI (https://console.groq.com)
GROQ_API_KEY=

# Email (para notificações — opcional)
EMAIL_SERVER=
EMAIL_FROM=

# Cron (Vercel) — protege /api/cron/* — gere com: openssl rand -base64 32
# Vercel envia automaticamente como header Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
